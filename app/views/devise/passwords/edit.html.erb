<div class="page-wrapper">
  <div class="movie-form" style="margin: 0 auto;">
    <h1>Change your password</h1>

    <%= form_with(model: resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= f.hidden_field :reset_password_token %>

      <div class="form-group">
        <%= f.label :password, "New password" %>
        <% if @minimum_password_length %>
          <small style="color: #666; margin-left: 0.5rem;">(<%= @minimum_password_length %> characters minimum)</small>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm new password" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Change password", class: "btn-primary" %>
      </div>
    <% end %>

    <div style="margin-top: 1.5rem; font-size: 0.875rem; color: #777;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
