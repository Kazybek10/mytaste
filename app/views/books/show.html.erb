<div class="page-wrapper">
  <div class="show-card">
    <div class="show-cover-container">
      <% if @book.cover_image.attached? && @book.cover_image.image? %>
        <% begin %>
          <%= image_tag url_for(@book.cover_image.variant(resize_to_limit: [400, 600])), class: "show-cover" %>
        <% rescue StandardError %>
          <div class="show-cover-placeholder"><span>No Image</span></div>
        <% end %>
      <% else %>
        <div class="show-cover-placeholder"><span>No Image</span></div>
      <% end %>
    </div>

    <div class="show-info">
      <h1><%= @book.title %></h1>

      <div class="show-meta">
        <% if @book.author.present? %>
          <p><span class="meta-label">Author:</span> <%= @book.author %></p>
        <% end %>
        <% if @book.genre.present? %>
          <p><span class="meta-label">Genre:</span> <%= @book.genre %></p>
        <% end %>
        <% if @book.publish_year.present? %>
          <p><span class="meta-label">Published:</span> <%= @book.publish_year %></p>
        <% end %>
      </div>

      <% if @book.description.present? %>
        <div class="show-description">
          <span class="meta-label">Description</span>
          <p><%= @book.description %></p>
        </div>
      <% end %>

      <div class="show-actions">
        <%= link_to "← Back to Books", books_path, class: "btn-outline" %>
        <% if user_signed_in? && current_user == @book.user %>
          <%= link_to "Edit", edit_book_path(@book), class: "btn-outline", data: { turbo_frame: "modal-content" } %>
          <%= link_to "Delete", @book, class: "btn-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
