<div id="search-results">
  <div class="book-grid">
    <% @books.each do |book| %>
      <div class="book-card">
        <%= link_to book_path(book), class: "book-card-link" do %>
          <div class="book-cover-container">
            <% if book.cover_image.attached? && book.cover_image.image? %>
              <% begin %>
                <%= image_tag url_for(book.cover_image.variant(resize_to_limit: [240, 360])), class: "book-cover" %>
              <% rescue StandardError %>
                <% if book.cover_url? %>
                  <%= image_tag book.cover_url, class: "book-cover" %>
                <% else %>
                  <div class="book-cover-placeholder"><span class="placeholder-text">No Image</span></div>
                <% end %>
              <% end %>
            <% elsif book.cover_url? %>
              <%= image_tag book.cover_url, class: "book-cover" %>
            <% else %>
              <div class="book-cover-placeholder"><span class="placeholder-text">No Image</span></div>
            <% end %>
          </div>
          <h3 class="book-title"><%= book.title %></h3>
        <% end %>
        <div class="book-info">
          <p class="book-author"><%= book.author %></p>
          <% if book.genre.present? %>
            <p class="book-genre"><%= book.genre %></p>
          <% end %>
          <% if book.publish_year.present? %>
            <p class="book-year"><%= book.publish_year %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="pagination-container">
    <% if defined?(@pagy) && @pagy.pages > 1 %>
      <%= raw pagy_nav(@pagy) %>
    <% end %>
  </div>
</div>
