<div id="search-results">
  <div class="book-grid">
    <% @books.each do |book| %>
      <div class="book-card">
        <div class="book-cover-container">
          <% if book.cover_image.attached? && book.cover_image.image? %>
            <% begin %>
              <%= image_tag url_for(book.cover_image.variant(resize_to_limit: [120, 180])), class: "book-cover" %>
            <% rescue StandardError %>
              <div class="book-cover-placeholder">
                <span class="placeholder-text">No Image</span>
              </div>
            <% end %>
          <% else %>
            <div class="book-cover-placeholder">
              <span class="placeholder-text">No Image</span>
            </div>
          <% end %>
        </div>
        <div class="book-info">
          <div>
            <h3><%= link_to book.title, book_path(book), class: "book-title-link" %></h3>
            <p class="book-author"><%= book.author %></p>
            <% if book.genre.present? %>
              <p class="book-genre">Genre: <%= book.genre %></p>
            <% end %>
            <p class="book-year">Published: <%= book.publish_year %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="pagination-container">
    <% if defined?(@pagy) && @pagy.pages > 1 %>
      <%= pagination_nav(@pagy, :books_path) %>
    <% end %>
  </div>
</div>
