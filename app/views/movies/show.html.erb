<div class="show-hero">
  <% cover = @movie.cover_image.attached? ? url_for(@movie.cover_image) : @movie.poster_url %>
  <% if cover %>
    <div class="show-hero-bg" style="background-image: url('<%= cover %>')"></div>
  <% end %>
  <div class="show-hero-overlay"></div>

  <div class="show-hero-content">
    <div class="show-cover-wrap">
      <% if @movie.cover_image.attached? && @movie.cover_image.image? %>
        <%= image_tag url_for(@movie.cover_image.variant(resize_to_limit: [320, 480])), class: "show-cover-img" %>
      <% elsif @movie.poster_url? %>
        <%= image_tag @movie.poster_url, class: "show-cover-img" %>
      <% else %>
        <div class="show-cover-blank"><span>No Image</span></div>
      <% end %>
    </div>

    <div class="show-details">
      <h1 class="show-title"><%= @movie.title %></h1>

      <% if @movie.director.present? %>
        <p class="show-author"><%= @movie.director %></p>
      <% end %>

      <div class="show-tags">
        <% if @movie.genre.present? %>
          <span class="show-tag"><%= @movie.genre %></span>
        <% end %>
        <% if @movie.release_year.present? %>
          <span class="show-tag"><%= @movie.release_year %></span>
        <% end %>
      </div>

      <% if @movie.description.present? %>
        <p class="show-description"><%= @movie.description %></p>
      <% end %>

      <% if user_signed_in? %>
        <div class="user-item-actions">
          <% if @user_item %>
            <div class="status-badges">
              <%= button_to "Want to watch", update_status_movie_path(@movie),
                  method: :patch, params: { status: "want" },
                  class: "status-btn #{"active" if @user_item.status == "want"}" %>
              <%= button_to "Watching", update_status_movie_path(@movie),
                  method: :patch, params: { status: "watching" },
                  class: "status-btn #{"active" if @user_item.status == "watching"}" %>
              <%= button_to "Completed", update_status_movie_path(@movie),
                  method: :patch, params: { status: "completed" },
                  class: "status-btn #{"active" if @user_item.status == "completed"}" %>
            </div>

            <div class="rating-row">
              <% (1..5).each do |star| %>
                <%= button_to "★", update_status_movie_path(@movie),
                    method: :patch,
                    params: { status: @user_item.status, rating: star },
                    class: "star-btn #{"filled" if @user_item.rating && star <= @user_item.rating}" %>
              <% end %>
            </div>

            <%= button_to "Remove from list", remove_from_list_movie_path(@movie),
                method: :delete, class: "btn-danger" %>
          <% else %>
            <%= button_to "＋ Add to my list", add_to_list_movie_path(@movie),
                method: :post, params: { status: "want" }, class: "btn-add" %>
          <% end %>
        </div>
      <% end %>

      <div class="show-actions">
        <%= link_to "← Back", movies_path, class: "btn-outline" %>
        <% if user_signed_in? %>
          <% if @movie.tmdb_id.nil? %>
            <%= link_to "Edit", edit_movie_path(@movie), class: "btn-outline" %>
          <% end %>
          <%= button_to "Delete from site", @movie, method: :delete, class: "btn-danger", data: { turbo_confirm: "Remove this movie from the site?" } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
