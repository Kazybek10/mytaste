<div class="page-wrapper">
  <div class="top-actions">
    <h1>Movies</h1>
    <% if user_signed_in? %>
      <%= link_to "+ Add Movie", new_movie_path, class: "new-item-link" %>
    <% end %>
  </div>

  <div data-controller="search" data-search-url-value="<%= movies_path %>">
    <div class="search-and-form">
      <input
        type="text"
        placeholder="Search movies..."
        class="search-input"
        data-search-target="input"
        data-action="input->search#search"
        value="<%= params[:query] %>">
    </div>

    <hr>

    <div data-search-target="results">
      <%= render "movies_list" %>
    </div>
  </div>
</div>
