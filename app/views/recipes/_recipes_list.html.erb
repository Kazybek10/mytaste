<div id="search-results">
  <div class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <div class="recipe-card">
        <%= link_to recipe_path(recipe), class: "recipe-card-link" do %>
          <div class="recipe-cover-container">
            <% if recipe.cover_image.attached? && recipe.cover_image.image? %>
              <% begin %>
                <%= image_tag url_for(recipe.cover_image.variant(resize_to_limit: [240, 360])), class: "recipe-cover" %>
              <% rescue StandardError %>
                <% if recipe.cover_url? %>
                  <%= image_tag recipe.cover_url, class: "recipe-cover" %>
                <% else %>
                  <div class="recipe-cover-placeholder"><span class="placeholder-text">No Image</span></div>
                <% end %>
              <% end %>
            <% elsif recipe.cover_url? %>
              <%= image_tag recipe.cover_url, class: "recipe-cover" %>
            <% else %>
              <div class="recipe-cover-placeholder"><span class="placeholder-text">No Image</span></div>
            <% end %>
          </div>
          <h3 class="recipe-title"><%= recipe.title %></h3>
        <% end %>
        <div class="recipe-info">
          <% if recipe.ingredients.present? %>
            <p class="recipe-ingredients"><%= truncate(recipe.ingredients, length: 60, separator: ' ') %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="pagination-container">
    <% if defined?(@pagy) && @pagy.pages > 1 %>
      <%= raw pagy_nav(@pagy) %>
    <% end %>
  </div>
</div>
