<div id="search-results">
  <div class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <div class="recipe-card">
        <div class="recipe-cover-container">
          <% if recipe.cover_image.attached? && recipe.cover_image.image? %>
            <% begin %>
              <%= image_tag url_for(recipe.cover_image.variant(resize_to_limit: [120, 180])), class: "recipe-cover" %>
            <% rescue StandardError %>
              <div class="recipe-cover-placeholder">
                <span class="placeholder-text">No Image</span>
              </div>
            <% end %>
          <% else %>
            <div class="recipe-cover-placeholder">
              <span class="placeholder-text">No Image</span>
            </div>
          <% end %>
        </div>
        <div class="recipe-info">
          <div>
            <h3><%= link_to recipe.title, recipe_path(recipe), class: "recipe-title-link" %></h3>
            <p class="recipe-ingredients"><strong>Ingredients:</strong> <%= truncate(recipe.ingredients, length: 50, separator: ' ') %></p>
            <% if user_signed_in? %>
              <div data-star-rating
                   data-initial-rating="<%= recipe.rating || 0 %>"
                   data-resource-type="recipes"
                   data-resource-id="<%= recipe.id %>">
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="pagination-container">
    <% if defined?(@pagy) && @pagy.pages > 1 %>
      <%= pagination_nav(@pagy, :recipes_path) %>
    <% end %>
  </div>
</div>
