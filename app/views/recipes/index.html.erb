<div class="page-wrapper">
  <div class="top-actions">
    <h1>Recipes</h1>
  </div>
  <hr>

  <% if user_signed_in? %>
    <div class="api-search-wrap"
         data-controller="api-search"
         data-api-search-search-url-value="<%= api_search_recipes_path %>"
         data-api-search-import-url-value="<%= api_import_recipes_path %>"
         data-api-search-id-param-value="meal_id">
      <div class="api-search-field">
        <input type="text"
               class="form-control api-index-search"
               placeholder="Search a recipe to add..."
               data-api-search-target="input"
               data-action="input->api-search#search blur->api-search#closeResults"
               autocomplete="off" />
        <span class="api-spinner" data-api-search-target="spinner">⟳</span>
      </div>
      <div class="api-results" data-api-search-target="results"></div>
    </div>
  <% end %>

  <%= render "recipes_list" %>
</div>
