<div class="show-hero">
  <% cover = @recipe.cover_image.attached? ? url_for(@recipe.cover_image) : @recipe.cover_url %>
  <% if cover %>
    <div class="show-hero-bg" style="background-image: url('<%= cover %>')"></div>
  <% end %>
  <div class="show-hero-overlay"></div>

  <div class="show-hero-content">
    <div class="show-cover-wrap">
      <% if @recipe.cover_image.attached? && @recipe.cover_image.image? %>
        <%= image_tag url_for(@recipe.cover_image.variant(resize_to_limit: [320, 480])), class: "show-cover-img" %>
      <% elsif @recipe.cover_url? %>
        <%= image_tag @recipe.cover_url, class: "show-cover-img" %>
      <% else %>
        <div class="show-cover-blank"><span>No Image</span></div>
      <% end %>
    </div>

    <div class="show-details">
      <h1 class="show-title"><%= @recipe.title %></h1>

      <% if user_signed_in? %>
        <div class="user-item-actions">
          <% if @user_item %>
            <div class="status-badges">
              <%= button_to "Want to try", update_status_recipe_path(@recipe),
                  method: :patch, params: { status: "want" },
                  class: "status-btn #{"active" if @user_item.status == "want"}" %>
              <%= button_to "Trying", update_status_recipe_path(@recipe),
                  method: :patch, params: { status: "watching" },
                  class: "status-btn #{"active" if @user_item.status == "watching"}" %>
              <%= button_to "Made it", update_status_recipe_path(@recipe),
                  method: :patch, params: { status: "completed" },
                  class: "status-btn #{"active" if @user_item.status == "completed"}" %>
            </div>

            <div class="rating-row">
              <% (1..5).each do |star| %>
                <%= button_to "★", update_status_recipe_path(@recipe),
                    method: :patch,
                    params: { status: @user_item.status, rating: star },
                    class: "star-btn #{"filled" if @user_item.rating && star <= @user_item.rating}",
                    form: { data: { turbo: false } } %>
              <% end %>
            </div>

            <%= button_to "Remove from list", remove_from_list_recipe_path(@recipe),
                method: :delete, class: "btn-danger" %>

            <%= render "shared/user_notes", user_item: @user_item,
                update_status_path: update_status_recipe_path(@recipe) %>
          <% else %>
            <%= button_to "＋ Add to my list", add_to_list_recipe_path(@recipe),
                method: :post, params: { status: "want" }, class: "btn-add" %>
          <% end %>
        </div>
      <% end %>

      <% if @recipe.ingredients.present? %>
        <div class="show-section">
          <p class="show-section-label">Ingredients</p>
          <p class="show-description"><%= @recipe.ingredients %></p>
        </div>
      <% end %>

      <% if @recipe.instructions.present? %>
        <div class="show-section">
          <p class="show-section-label">Instructions</p>
          <p class="show-description"><%= @recipe.instructions %></p>
        </div>
      <% end %>

      <div class="show-actions">
        <%= link_to "← Back", recipes_path, class: "btn-outline" %>
        <% if user_signed_in? %>
          <% if @recipe.meal_id.nil? %>
            <%= link_to "Edit", edit_recipe_path(@recipe), class: "btn-outline" %>
          <% end %>
          <%= button_to "Delete from site", @recipe, method: :delete, class: "btn-danger", data: { turbo_confirm: "Remove this recipe from the site?" } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
