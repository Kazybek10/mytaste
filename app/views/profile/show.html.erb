<div class="page-wrapper profile-page">

  <div class="profile-hero">
    <div class="profile-hero-avatar">
      <% if current_user.avatar.attached? %>
        <img src="<%= url_for(current_user.avatar) %>" class="profile-avatar-img" />
      <% else %>
        <div class="profile-avatar">
          <%= current_user.display_name.upcase.first %>
        </div>
      <% end %>
    </div>
    <div class="profile-hero-info">
      <h1 class="profile-title"><%= current_user.display_name %></h1>
      <div class="profile-stats-inline">
        <span><strong><%= @stats[:movies].values.sum %></strong> Movies</span>
        <span class="profile-stats-dot">·</span>
        <span><strong><%= @stats[:books].values.sum %></strong> Books</span>
        <span class="profile-stats-dot">·</span>
        <span><strong><%= @stats[:recipes].values.sum %></strong> Recipes</span>
      </div>
      <%= link_to "Edit profile", edit_profile_path, class: "btn-outline profile-edit-btn" %>
    </div>
  </div>


  <%# === WATCH LISTS === %>
  <div class="profile-section">
    <div class="profile-section-header">
      <h2 class="profile-section-title">My Lists</h2>
      <% if @watch_lists.size < 10 %>
        <button class="btn-outline" data-action="click->modal#open" data-turbo-frame="modal-content"
                onclick="document.getElementById('new-list-form').classList.toggle('hidden'); return false;">
          + New list
        </button>
      <% end %>
    </div>

    <div id="new-list-form" class="hidden">
      <%= form_with url: watch_lists_path, local: true, class: "inline-form" do |f| %>
        <%= f.text_field :name, class: "form-control", placeholder: "List name...", required: true, data: { watch_list: { name: "" } }, name: "watch_list[name]" %>
        <%= f.submit "Create", class: "btn-primary" %>
      <% end %>
    </div>

    <% if @watch_lists.any? %>
      <div class="watch-lists-grid"
           data-controller="sortable"
           data-sortable-url-value="<%= reorder_watch_lists_path %>">
        <% @watch_lists.each do |wl| %>
          <div class="watch-list-card" data-controller="inline-edit" data-id="<%= wl.id %>">
            <div class="watch-list-header">
              <span class="watch-list-name" data-inline-edit-target="display"><%= wl.name %></span>
              <%= form_with model: wl, url: watch_list_path(wl), method: :patch, local: true,
                  class: "hidden", data: { "inline-edit-target": "form" } do |f| %>
                <%= f.text_field :name, class: "form-control form-control-sm", value: wl.name %>
                <%= f.submit "Save", class: "btn-primary btn-sm" %>
                <button type="button" class="btn-outline btn-sm" data-action="click->inline-edit#cancel">Cancel</button>
              <% end %>
              <div class="watch-list-actions" data-inline-edit-target="actions">
                <button class="btn-outline btn-sm" data-action="click->inline-edit#edit">Rename</button>
                <%= button_to "Delete", watch_list_path(wl), method: :delete, class: "btn-danger btn-sm",
                    data: { turbo_confirm: "Delete this list?" } %>
              </div>
            </div>

            <div class="watch-list-stats">
              <span><%= wl.user_items.where(itemable_type: "Movie").count %> movies</span>
              <span><%= wl.user_items.where(itemable_type: "Book").count %> books</span>
              <span><%= wl.user_items.where(itemable_type: "Recipe").count %> recipes</span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="chart-empty">No lists yet. Create your first list!</p>
    <% end %>
  </div>

  <%# === STATUS SECTIONS === %>
  <%
    status_labels = {
      movies:  { want: "Want to watch", watching: "Watching",  completed: "Completed" },
      books:   { want: "Want to read",  watching: "Reading",   completed: "Completed" },
      recipes: { want: "Want to try",   watching: "Trying",    completed: "Made it"   }
    }
    type_map = { "Movie" => :movies, "Book" => :books, "Recipe" => :recipes }
  %>

  <% [:want, :watching, :completed].each do |status| %>
    <% list = @lists[status] %>
    <% next if list.empty? %>

    <div class="profile-section">
      <h2 class="profile-section-title">
        <%= status.to_s.capitalize %>
        <span class="profile-section-count"><%= list.size %></span>
      </h2>
      <div class="recent-grid">
        <% list.each do |user_item| %>
          <% item = user_item.itemable %>
          <% next unless item %>
          <% category = type_map[item.class.name] %>
          <% label = status_labels.dig(category, status) %>
          <% cover = item.try(:poster_url) || item.try(:cover_url) %>
          <%= link_to polymorphic_path(item), class: "recent-card" do %>
            <% if cover %>
              <img src="<%= cover %>" class="recent-cover" />
            <% elsif item.try(:cover_image)&.attached? %>
              <%= image_tag url_for(item.cover_image), class: "recent-cover" %>
            <% else %>
              <div class="recent-cover-blank"></div>
            <% end %>
            <p class="recent-title"><%= item.title %></p>
            <span class="recent-status <%= status %>"><%= label %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
