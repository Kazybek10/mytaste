<div class="page-wrapper profile-page">
  <div class="top-actions">
    <h1>Edit Profile</h1>
    <%= link_to "← Back", profile_path, class: "btn-outline" %>
  </div>

  <%= form_with model: current_user, url: profile_path, method: :patch, local: true, html: { multipart: true, class: "profile-edit-form" } do |f| %>
    <% if current_user.errors.any? %>
      <div class="form-errors">
        <% current_user.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="profile-edit-avatar" data-controller="avatar-preview">
      <% if current_user.avatar.attached? %>
        <img src="<%= url_for(current_user.avatar) %>" class="avatar-preview-img" data-avatar-preview-target="preview" />
      <% else %>
        <div class="avatar-placeholder" data-avatar-preview-target="placeholder">
          <%= current_user.display_name.upcase.first %>
        </div>
        <img class="avatar-preview-img hidden" data-avatar-preview-target="preview" />
      <% end %>
      <%= f.file_field :avatar, id: "avatar-upload", class: "avatar-file-input", accept: "image/*",
          data: { action: "change->avatar-preview#show", "avatar-preview-target": "input" } %>
      <label for="avatar-upload" class="avatar-upload-label">Change photo</label>
    </div>

    <div class="form-group">
      <%= f.label :username, "Username" %>
      <%= f.text_field :username, class: "form-control", placeholder: current_user.email.split("@").first %>
    </div>

    <div class="form-group">
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, class: "form-control" %>
    </div>

    <hr class="form-divider">
    <p class="form-hint">Leave password blank to keep current</p>

    <div class="form-group">
      <%= f.label :password, "New password" %>
      <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, "Confirm new password" %>
      <%= f.password_field :password_confirmation, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= f.label :current_password, "Current password (required to save changes)" %>
      <%= f.password_field :current_password, class: "form-control", autocomplete: "current-password" %>
    </div>

    <div class="form-actions">
      <%= f.submit "Save changes", class: "btn-primary" %>
    </div>
  <% end %>
</div>
